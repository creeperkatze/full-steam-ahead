{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Full Steam Ahead",
  "version": "../package.json",
  "identifier": "dev.creeperkatze.full-steam-ahead",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Full Steam Ahead",
        "width": 1200,
        "height": 680,
        "minWidth": 1200,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
