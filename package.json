  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-svg-loader": "^5.1.0",
    "vue-tsc": "^2.0.22"
  }
